# Required — get these from console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Required — get from platform.openai.com
OPENAI_API_KEY=sk-...

# Required — your public-facing server URL (ngrok URL for local dev)
BASE_URL=https://your-ngrok-url.ngrok-free.app

# Optional — defaults to 3000
PORT=3000

# Optional — phone number to transfer to when AI escalates to human
HUMAN_AGENT_NUMBER=+19198893874

# Optional — OpenAI model (defaults to gpt-4o)
OPENAI_MODEL=gpt-4o
